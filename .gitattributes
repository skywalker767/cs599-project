# Normalize text files to LF in the repository (avoids single-line Raw view issues)
* text=auto eol=lf

*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.env.example text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text eol=lf
