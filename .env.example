# =============================================================================
# Spec2Vision / VisionFlow – Environment Configuration
# Copy to .env:  cp .env.example .env   (Windows: copy .env.example .env)
#
# REQUIRED for clone-and-run (defaults below work with NO API keys):
#   LLM_PROVIDER=mock
#   IMAGE_PROVIDER=mock
#
# OPTIONAL – only when using external APIs:
#   OPENAI_API_KEY      required if LLM_PROVIDER=openai or IMAGE_PROVIDER=openai
#   DEEPSEEK_API_KEY    required if LLM_PROVIDER=deepseek
#   IMAGE_API_KEY       optional override for image API (falls back to OPENAI_API_KEY)
# =============================================================================

# Application
APP_NAME=VisionFlow
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Reproducible demo (no paid API keys required)
# When true: uses mock LLM + mock image provider automatically
DEMO_MODE=false
WORKFLOW_DEBUG=false

# Database
DATABASE_URL=sqlite:///./storage/visionflow.db

# Storage paths (relative to project root)
STORAGE_ROOT=storage

# Text LLM: openai | deepseek | mock (default mock for clone-and-run)
LLM_PROVIDER=mock
LLM_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Image generation: openai | mock (default mock – no API key needed)
IMAGE_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
IMAGE_API_KEY=

# Optional VLM evaluator (requires OPENAI_API_KEY when set to openai)
VISION_EVALUATOR_PROVIDER=none

# OCR for scanned PDFs (none | tesseract – reserved, not enabled by default)
OCR_PROVIDER=none

OPENAI_MODEL=gpt-4o-mini

# Quality thresholds
MIN_QUALITY_SCORE=0.6
MAX_REVISION_ROUNDS=2
